    "@tarojs/plugin-platform-tt": "4.0.5",
    "@tarojs/plugin-platform-weapp": "4.0.5",
    "@tarojs/react": "4.0.5",
    "@tarojs/router": "4.0.5",
    "@tarojs/runtime": "4.0.5",
    "@tarojs/shared": "4.0.5",
    "@tarojs/taro": "4.0.5",
    "react": "^18.2.0",
