{
  "name": "example-taro-vue",
  "description": "Taro + Vue 3 captcha example",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build:weapp": "taro build --type weapp",
    "build:swan": "taro build --type swan",
    "build:alipay": "taro build --type alipay",
    "build:tt": "taro build --type tt",
    "build:h5": "taro build --type h5",
    "build:qq": "taro build --type qq",
    "build:jd": "taro build --type jd",
    "dev:weapp": "npm run build:weapp -- --watch",
    "dev:swan": "npm run build:swan -- --watch",
    "dev:alipay": "npm run build:alipay -- --watch",
    "dev:tt": "npm run build:tt -- --watch",
    "dev:h5": "npm run build:h5 -- --watch",
    "dev:qq": "npm run build:qq -- --watch",
    "dev:jd": "npm run build:jd -- --watch"
  },
  "browserslist": [
    "last 3 versions",
    "Android >= 4.1",
    "ios >= 8"
  ],
  "dependencies": {
    "@babel/runtime": "^7.29.7",
    "@captcha-pro/taro-vue": "workspace:*",
    "@tarojs/components": "3.6.40",
    "@tarojs/helper": "3.6.40",
    "@tarojs/plugin-framework-vue3": "3.6.40",
    "@tarojs/plugin-platform-alipay": "3.6.40",
    "@tarojs/plugin-platform-h5": "3.6.40",
    "@tarojs/plugin-platform-jd": "3.6.40",
    "@tarojs/plugin-platform-qq": "3.6.40",
    "@tarojs/plugin-platform-swan": "3.6.40",
    "@tarojs/plugin-platform-tt": "3.6.40",
    "@tarojs/plugin-platform-weapp": "3.6.40",
    "@tarojs/runtime": "3.6.40",
    "@tarojs/shared": "3.6.40",
    "@tarojs/taro": "3.6.40",
    "vue": "^3.5.39"
  },
  "devDependencies": {
    "@babel/core": "^7.29.7",
    "@tarojs/binding-darwin-x64": "4.2.0",
    "@tarojs/cli": "3.6.40",
    "@tarojs/webpack5-runner": "3.6.40",
    "babel-preset-taro": "3.6.40",
    "css-loader": "3.6.0",
    "eslint": "^8.57.1",
    "eslint-config-taro": "3.6.40",
    "eslint-plugin-vue": "^8.7.1",
