{
  "name": "taro-vue-example",
  "version": "1.0.0",
  "private": true,
  "description": "Taro + Vue 3 captcha example",
  "scripts": {
    "build:weapp": "taro build --type weapp",
    "build:swan": "taro build --type swan",
    "build:alipay": "taro build --type alipay",
    "build:tt": "taro build --type tt",
    "build:h5": "taro build --type h5",
    "build:qq": "taro build --type qq",
    "build:jd": "taro build --type jd",
    "dev:weapp": "npm run build:weapp -- --watch",
    "dev:swan": "npm run build:swan -- --watch",
    "dev:alipay": "npm run build:alipay -- --watch",
    "dev:tt": "npm run build:tt -- --watch",
    "dev:h5": "npm run build:h5 -- --watch",
    "dev:qq": "npm run build:qq -- --watch",
    "dev:jd": "npm run build:jd -- --watch"
  },
  "browserslist": ["last 3 versions", "Android >= 4.1", "ios >= 8"],
  "dependencies": {
    "@babel/runtime": "^7.7.7",
    "@captcha/mp": "workspace:*",
    "@tarojs/components": "4.0.5",
    "@tarojs/helper": "4.0.5",
    "@tarojs/plugin-framework-vue3": "4.0.5",
    "@tarojs/plugin-platform-weapp": "4.0.5",
    "@tarojs/plugin-platform-alipay": "4.0.5",
    "@tarojs/plugin-platform-tt": "4.0.5",
    "@tarojs/plugin-platform-swan": "4.0.5",
    "@tarojs/plugin-platform-jd": "4.0.5",
    "@tarojs/plugin-platform-qq": "4.0.5",
    "@tarojs/plugin-platform-h5": "4.0.5",
    "@tarojs/runtime": "4.0.5",
    "@tarojs/shared": "4.0.5",
    "@tarojs/taro": "4.0.5",
    "vue": "^3.3.0"
  },
  "devDependencies": {
    "@babel/core": "^7.8.0",
    "@tarojs/cli": "4.0.5",
    "@tarojs/webpack5-runner": "4.0.5",
    "babel-preset-taro": "4.0.5",
    "css-loader": "3.4.2",
    "eslint": "^8.12.0",
    "eslint-config-taro": "4.0.5",
    "eslint-plugin-vue": "^8.0.0",
    "postcss": "^8.4.18",
    "sass": "^1.77.0",
    "style-loader": "1.3.0",
    "typescript": "^5.1.0",
    "vue-loader": "^17.0.0",
    "webpack": "^5.78.0"
  }
}
