    "@tarojs/plugin-framework-vue2": "3.6.37",
    "@tarojs/plugin-html": "3.6.37",
    "@tarojs/plugin-platform-alipay": "3.6.37",
    "@tarojs/plugin-platform-h5": "3.6.37",
    "@tarojs/plugin-platform-jd": "3.6.37",
    "@tarojs/plugin-platform-qq": "3.6.37",
    "@tarojs/plugin-platform-swan": "3.6.37",
    "@tarojs/plugin-platform-tt": "3.6.37",
    "@tarojs/plugin-platform-weapp": "3.6.37",
    "@tarojs/runtime": "3.6.37",
    "@tarojs/shared": "3.6.37",
    "@tarojs/taro": "3.6.37",
    "vue": "^2.7.16",
