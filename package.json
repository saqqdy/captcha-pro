{
  "name": "captcha-pro-monorepo",
  "description": "A lightweight behavioral captcha library with slider puzzle and click verification - Monorepo",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@9.15.3",
  "scripts": {
    "build": "turbo build",
    "build:core": "pnpm --filter @captcha/core build",
    "build:vue3": "pnpm --filter @captcha/vue3 build",
    "build:vue2": "pnpm --filter @captcha/vue2 build",
    "build:react": "pnpm --filter @captcha/react build",
    "build:mp": "pnpm --filter @captcha/mp build",
    "test": "turbo test",
    "lint": "eslint --fix .",
    "prettier": "prettier --write \"**/*.{js,ts,jsx,tsx,vue,yml,json,md}\"",
    "clean": "turbo clean && rm -rf node_modules",
    "dev": "pnpm --filter @captcha/core watch",
    "dev:core": "pnpm --filter @captcha/core watch",
    "dev:vue3": "pnpm --filter @captcha/vue3 watch",
    "dev:vue2": "pnpm --filter @captcha/vue2 watch",
    "dev:react": "pnpm --filter @captcha/react watch",
    "dev:mp": "pnpm --filter @captcha/mp watch",
    "pub": "pnpm -r publish --access public",
    "changeset": "changeset",
    "version": "changeset version"
  },
  "devDependencies": {
    "@changesets/cli": "^2.28.0",
    "@eslint-sets/eslint-config": "^6.2.0",
    "@types/node": "^25.5.0",
    "eslint": "^9.22.0",
    "prettier": "^3.8.1",
    "prettier-config-common": "^1.5.0",
    "turbo": "^2.4.0",
    "typescript": "^5.7.3"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "captcha",
    "behavioral-captcha",
    "slider-captcha",
    "puzzle-captcha",
    "click-captcha",
    "monorepo"
  ],
  "license": "MIT",
  "author": "saqqdy<https://github.com/saqqdy>",
  "homepage": "https://github.com/saqqdy/captcha-pro#readme",
  "bugs": {
    "url": "https://github.com/saqqdy/captcha-pro/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/saqqdy/captcha-pro.git"
  }
}
