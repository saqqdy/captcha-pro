{
	"name": "captcha-pro",
	"description": "A lightweight behavioral captcha library with slider puzzle and click verification, framework-agnostic",
	"version": "1.1.0",
	"packageManager": "pnpm@9.15.3",
	"main": "dist/index.cjs",
	"module": "dist/index.mjs",
	"browser": "dist/index.global.min.js",
	"unpkg": "dist/index.global.min.js",
	"jsdelivr": "dist/index.global.min.js",
	"types": "dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"browser": {
				"production": "./dist/index.global.min.js",
				"development": "./dist/index.global.js",
				"default": "./dist/index.global.min.js"
			},
			"require": "./dist/index.cjs",
			"import": "./dist/index.mjs",
			"default": "./dist/index.mjs"
		},
		"./package.json": "./package.json"
	},
	"directories": {
		"dist": "dist",
		"src": "src"
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "run-s clean build:{bundle,types}",
		"build:bundle": "rolldown -c build/rolldown.config.ts",
		"build:types": "tsc -p src/tsconfig.json && pnpm roll-types",
		"deploy": "sh scripts/deploy.sh",
		"roll-types": "api-extractor run && rm-all temp",
		"circular": "madge dist/ -c",
		"watch": "rolldown -c build/rolldown.config.ts -w",
		"pub": "tscjs scripts/publish",
		"unpub": "tscjs scripts/unpublish",
		"sync": "tscjs scripts/sync",
		"workflow:publish-test": "zx scripts/workflow.mjs",
		"clean": "rm-all dist es lib",
		"dist": "run-s lint prettier build",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:coverage": "vitest run --coverage",
		"lint": "eslint --fix .",
		"prettier": "prettier --write \"**/*.{js,ts,jsx,tsx,yml,json,md}\""
	},
	"dependencies": {
		"js-cool": "^5.23.2"
	},
	"devDependencies": {
		"@eslint-sets/eslint-config": "^6.2.0",
		"@microsoft/api-extractor": "^7.49.1",
		"@types/node": "^24.12.0",
		"@vitest/coverage-istanbul": "^4.1.0",
		"@vitest/coverage-v8": "4.1.0",
		"cross-env": "^7.0.3",
		"eslint": "^9.22.0",
		"fast-glob": "^3.3.3",
		"happy-dom": "^20.8.3",
		"load-yml": "^1.4.0",
		"madge": "^8.0.0",
		"npm-run-all": "^4.1.5",
		"prettier": "^3.8.1",
		"prettier-config-common": "^1.5.0",
		"reinstaller": "^3.0.2",
		"rm-all": "^1.1.1",
		"rolldown": "^1.0.0-rc.9",
		"rollup-plugin-filesize": "^10.0.0",
		"rollup-plugin-visualizer": "^5.14.0",
		"tsnd": "^1.1.0",
		"typescript": "^5.7.3",
		"vitest": "^4.1.0",
		"zx": "^8.8.5"
	},
	"peerDependencies": {
		"js-cool": ">= 2"
	},
	"engines": {
		"node": ">=18"
	},
	"browserslist": [
		">= 0.5%",
		"last 2 versions",
		"Firefox ESR",
		"not dead",
		"ie >= 11"
	],
	"sideEffects": false,
	"pnpm": {
		"peerDependencyRules": {
			"ignoreMissing": [
				"webpack"
			],
			"allowedVersions": {
				"@types/node": "^18.0.0"
			}
		}
	},
	"keywords": [
		"captcha",
		"behavioral-captcha",
		"slider-captcha",
		"puzzle-captcha",
		"click-captcha",
		"slider-puzzle",
		"verification",
		"framework-agnostic",
		"typescript",
		"captcha-pro",
		"saqqdy"
	],
	"license": "MIT",
	"author": "saqqdy<https://github.com/saqqdy>",
	"homepage": "https://github.com/saqqdy/captcha-pro#readme",
	"bugs": {
		"url": "https://github.com/saqqdy/captcha-pro/issues"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/saqqdy/captcha-pro.git"
	},
	"funding": "https://github.com/sponsors/saqqdy",
	"publishConfig": {
		"registry": "https://registry.npmjs.org",
		"access": "public"
	}
}
