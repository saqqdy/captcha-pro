{
  "name": "@captcha-pro/core",
  "description": "Core library for captcha-pro - framework agnostic behavioral captcha",
  "version": "1.0.0",
  "main": "dist/index.cjs",
  "module": "dist/index.mjs",
  "browser": "dist/index.global.min.js",
  "unpkg": "dist/index.global.min.js",
  "jsdelivr": "dist/index.global.min.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.cjs",
      "import": "./dist/index.mjs",
      "browser": "./dist/index.global.min.js",
      "default": "./dist/index.mjs"
    },
    "./style.css": "./dist/style.css",
    "./package.json": "./package.json"
  },
  "directories": {
    "dist": "dist",
    "src": "src"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "run-s clean build:{bundle,types,css}",
    "build:bundle": "rollup -c build/rollup.config.mjs",
    "build:types": "tsc -p src/tsconfig.json && pnpm roll-types",
    "build:css": "mkdir -p dist && cp src/styles/index.css dist/style.css",
    "roll-types": "api-extractor run && rm-all temp",
    "watch": "run-s build:css watch:bundle",
    "watch:bundle": "rollup -c build/rollup.config.mjs -w",
    "clean": "rm-all dist es lib",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint --fix ."
  },
  "dependencies": {
    "js-cool": "^5.23.2"
  },
  "devDependencies": {
    "@microsoft/api-extractor": "^7.58.9",
    "@rollup/plugin-replace": "^6.0.2",
    "@rollup/plugin-terser": "^0.4.4",
    "@rollup/plugin-typescript": "^12.1.2",
    "@types/node": "^24.13.3",
    "@vitest/coverage-v8": "4.1.10",
    "happy-dom": "^20.10.6",
    "npm-run-all": "^4.1.5",
    "rm-all": "^1.1.1",
    "rollup": "^4.40.0",
    "rollup-plugin-filesize": "^10.0.0",
    "rollup-plugin-visualizer": "^7.0.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.10"
  },
  "peerDependencies": {
    "js-cool": ">= 2"
  },
  "engines": {
    "node": ">=18"
  },
  "sideEffects": false,
  "keywords": [
    "captcha",
    "behavioral-captcha",
    "slider-captcha",
    "puzzle-captcha",
    "click-captcha",
    "framework-agnostic",
    "typescript"
  ],
  "license": "MIT",
  "author": "saqqdy<https://github.com/saqqdy>",
  "homepage": "https://github.com/saqqdy/captcha-pro#readme",
  "bugs": {
    "url": "https://github.com/saqqdy/captcha-pro/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/saqqdy/captcha-pro.git"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  }
}
