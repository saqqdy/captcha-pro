<view wx:if="{{visible}}" class="popup-captcha">
  <!-- Mask -->
  <view class="popup-mask" catchtap="onMaskTap" />

  <!-- Content card -->
  <view class="popup-content">
    <!-- Header -->
    <view class="popup-header">
      <text class="popup-title">{{title}}</text>
      <view wx:if="{{showClose}}" class="popup-close" catchtap="hide">
        <text>×</text>
      </view>
    </view>

    <!-- Captcha body -->
    <view class="popup-body">
      <slider-captcha
        wx:if="{{type === 'slider'}}"
        width="{{sliderOptions.width}}"
        height="{{sliderOptions.height}}"
        sliderWidth="{{sliderOptions.sliderWidth}}"
        sliderHeight="{{sliderOptions.sliderHeight}}"
        showRefresh="{{sliderOptions.showRefresh}}"
        backend="{{backend}}"
        bind:success="onSuccess"
        bind:fail="onFail"
        bind:refresh="onRefresh"
      />
      <click-captcha
        wx:else
        width="{{clickOptions.width}}"
        height="{{clickOptions.height}}"
        showRefresh="{{clickOptions.showRefresh}}"
        backend="{{backend}}"
        bind:success="onSuccess"
        bind:fail="onFail"
        bind:refresh="onRefresh"
      />
    </view>
  </view>
</view>
