{
  "name": "@captcha-pro/vue3",
  "description": "Vue 3 components for captcha-pro",
  "version": "1.0.0",
  "main": "dist/index.cjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.cjs",
      "import": "./dist/index.mjs",
      "default": "./dist/index.mjs"
    },
    "./style.css": "./dist/style.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "run-s clean build:{js,types}",
    "build:js": "vite build -c build/vite.config.ts",
    "build:types": "vue-tsc -p src/tsconfig.json --emitDeclarationOnly --outDir dist",
    "watch": "vite build -c build/vite.config.ts -w",
    "clean": "rm-all dist",
    "test": "vitest run"
  },
  "dependencies": {
    "@captcha-pro/core": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^24.13.3",
    "@vitejs/plugin-vue": "^6.0.7",
    "npm-run-all": "^4.1.5",
    "rm-all": "^1.1.1",
    "typescript": "^5.9.3",
    "vite": "^5.4.19",
    "vue": "^3.5.39",
    "vue-tsc": "^3.3.7"
  },
  "peerDependencies": {
    "vue": "^3.0.0"
  },
  "sideEffects": [
    "**/*.css"
  ],
  "keywords": [
    "captcha",
    "vue3",
    "vue",
    "slider-captcha",
    "click-captcha"
  ],
  "license": "MIT",
  "author": "saqqdy<https://github.com/saqqdy>",
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  }
}
