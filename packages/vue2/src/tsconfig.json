{
  "compilerOptions": {
    "target": "ESNext",
    "jsx": "preserve",
    "rootDir": ".",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "types": ["node"],
    "strict": true,
    "declaration": true,
    "declarationMap": true,
    "outDir": "../dist",
    "esModuleInterop": true,
    "skipLibCheck": true
  },
  "include": ["./**/*.ts", "./**/*.js", "./**/*.vue"],
  "exclude": ["../dist", "../node_modules"]
}
