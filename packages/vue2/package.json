{
  "name": "@captcha/vue2",
  "description": "Vue 2 components for captcha-pro",
  "version": "1.0.0",
  "main": "dist/index.cjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.cjs",
      "import": "./dist/index.mjs",
      "default": "./dist/index.mjs"
    },
    "./style.css": "./dist/style.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "run-s clean build:js",
    "build:js": "vite build -c build/vite.config.ts",
    "watch": "vite build -c build/vite.config.ts -w",
    "clean": "rm-all dist",
    "test": "vitest run"
  },
  "dependencies": {
    "@captcha/core": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^24.12.0",
    "npm-run-all": "^4.1.5",
    "rm-all": "^1.1.1",
    "typescript": "^5.7.3",
    "vite": "^4.5.14",
    "vite-plugin-vue2": "^2.0.3",
    "vue": "^2.7.0",
    "vue-template-compiler": "^2.7.16"
  },
  "peerDependencies": {
    "vue": "^2.6.0 || ^2.7.0"
  },
  "sideEffects": [
    "**/*.css"
  ],
  "keywords": [
    "captcha",
    "vue2",
    "vue",
    "slider-captcha",
    "click-captcha"
  ],
  "license": "MIT",
  "author": "saqqdy<https://github.com/saqqdy>",
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  }
}
