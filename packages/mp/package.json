{
  "name": "@captcha/mp",
  "description": "Mini-program components for captcha-pro (WeChat, uni-app, Taro)",
  "version": "1.0.0",
  "main": "dist/index.cjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.cjs",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./taro": {
      "types": "./dist/taro/index.d.ts",
      "require": "./dist/taro/index.cjs",
      "import": "./dist/taro/index.js",
      "default": "./dist/taro/index.js"
    },
    "./weixin": {
      "require": "./dist/weixin/index.cjs",
      "import": "./dist/weixin/index.js",
      "default": "./dist/weixin/index.js"
    },
    "./uniapp": {
      "require": "./dist/uniapp/index.cjs",
      "import": "./dist/uniapp/index.js",
      "default": "./dist/uniapp/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "run-s clean build:js",
    "build:js": "vite build -c build/vite.config.ts",
    "watch": "vite build -c build/vite.config.ts -w",
    "clean": "rm-all dist",
    "test": "vitest run"
  },
  "dependencies": {
    "@captcha/core": "workspace:*"
  },
  "devDependencies": {
    "@tarojs/components": "^4.0.0",
    "@tarojs/taro": "^4.0.0",
    "@types/node": "^25.5.0",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitejs/plugin-vue": "^6.0.5",
    "npm-run-all": "^4.1.5",
    "rm-all": "^1.1.1",
    "rolldown": "^1.0.0-rc.9",
    "typescript": "^5.7.3",
    "vite": "^8.0.1"
  },
  "peerDependencies": {
    "@tarojs/components": "^3.0.0 || ^4.0.0",
    "@tarojs/taro": "^3.0.0 || ^4.0.0"
  },
  "peerDependenciesMeta": {
    "@tarojs/components": {
      "optional": true
    },
    "@tarojs/taro": {
      "optional": true
    }
  },
  "keywords": [
    "captcha",
    "miniprogram",
    "weixin",
    "uniapp",
    "taro",
    "slider-captcha",
    "click-captcha"
  ],
  "license": "MIT",
  "author": "saqqdy<https://github.com/saqqdy>",
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  }
}
